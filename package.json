{
  "private": true,
  "name": "gopad-api",
  "version": "0.0.0",
  "type": "module",
  "description": "Etherpad for markdown with Go",
  "homepage": "https://github.com/gopad/gopad-api#readme",
  "license": "Apache-2.0",
  "author": "Thomas Boerger <thomas@webhippie.de>",
  "repository": "https://github.com/gopad/gopad-api.git",
  "bugs": {
    "url": "https://github.com/gopad/gopad-api/issues",
    "email": "gopad@webhippie.de"
  },
  "scripts": {
    "clean": "rimraf static/ dist/static.zip dist/static.tar.gz",
    "serve": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint ./frontend",
    "format": "eslint ./frontend --fix && prettier ./frontend --write",
    "openapi": "rimraf frontend/client && openapi-ts --input ./openapi/v1.yaml --output ./frontend/client",
    "test": "vitest run",
    "deps:upgrade": "ncu --upgrade"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vee-validate": "^5.0.0-beta.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "0.96.1",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/test-utils": "2.4.8",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.0",
    "globals": "17.5.0",
    "happy-dom": "20.9.0",
    "npm-check-updates": "21.0.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
